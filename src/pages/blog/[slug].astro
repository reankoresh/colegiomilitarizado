---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import PostMeta from "../../components/blog/PostMeta.astro";
import PostAuthor from "../../components/blog/PostAuthor.astro";
import { getAllPosts, getPostBySlug } from "../../lib/strapi/client";
import { renderStrapiBlocks } from "../../lib/strapi/blocks";

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts
    .filter((post) => Boolean(post.slug) && Boolean(post.publishedAt))
    .map((post) => ({
      params: { slug: post.slug },
    }));
}

const { slug } = Astro.params;
const post = slug ? await getPostBySlug(slug) : undefined;

if (!post) {
  return Astro.redirect("/blog");
}

const contentHtml = renderStrapiBlocks(post.content);
const seoTitle = post.seo?.metaTitle || post.title;
const seoDescription = post.seo?.metaDescription || post.excerpt;
const seoImage = post.seo?.shareImageUrl || post.coverImageUrl;
---

<Layout
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  seoImage={seoImage}
  seoType="article"
>
  <Navbar />

  <main class="mx-auto max-w-4xl px-4 pb-20 pt-40 sm:px-6">
    <article>
      {
        post.coverImageUrl && (
          <Image
            src={post.coverImageUrl}
            alt={post.title}
            width={1400}
            height={900}
            class="mb-8 h-auto w-full rounded-2xl object-cover"
          />
        )
      }

      <header class="space-y-4">
        <h1 class="m-0 text-4xl font-bold leading-tight text-stone-900 md:text-5xl">{post.title}</h1>
        <PostMeta post={post} />
      </header>

      {
        contentHtml ? (
          <section class="strapi-blocks mt-10" set:html={contentHtml} />
        ) : (
          <section class="mt-10 rounded-xl border border-stone-200 bg-white p-6 text-stone-600">
            Este post no tiene contenido aún.
          </section>
        )
      }

      <PostAuthor author={post.author} />
    </article>
  </main>
</Layout>

<style>
  :global(.strapi-blocks h1) {
    margin: 1.5rem 0 1rem;
    font-size: 2rem;
    line-height: 1.2;
    color: #1c1917;
  }

  :global(.strapi-blocks h2) {
    margin: 1.5rem 0 1rem;
    font-size: 1.75rem;
    line-height: 1.25;
    color: #1c1917;
  }

  :global(.strapi-blocks h3) {
    margin: 1.25rem 0 0.75rem;
    font-size: 1.35rem;
    line-height: 1.3;
    color: #1c1917;
  }

  :global(.strapi-blocks p) {
    margin: 0 0 1rem;
    color: #44403c;
    line-height: 1.7;
  }

  :global(.strapi-blocks ul),
  :global(.strapi-blocks ol) {
    margin: 0 0 1rem;
    padding-left: 1.25rem;
    color: #44403c;
  }

  :global(.strapi-blocks blockquote) {
    margin: 1.5rem 0;
    border-left: 4px solid #f97316;
    padding: 0.5rem 0 0.5rem 1rem;
    color: #57534e;
    background: #fff7ed;
    border-radius: 0.5rem;
  }

  :global(.strapi-blocks a) {
    color: #ea580c;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
