---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout>
  <Navbar />

  <main class="planteles-page">
    <img
      src="/planteles.png"
      alt="Planteles del Colegio Militarizado"
      class="planteles-image"
    />
  </main>
</Layout>

<style>
  .planteles-page {
    min-height: 100dvh;
    padding: 0;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .planteles-image {
    width: 98vw;
    height: 98dvh;
    display: block;
    object-fit: contain;
  }
</style>