---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout
  seoTitle="Centro de Servicios Digitales"
  seoDescription="Acceso al ecosistema digital del Colegio Militarizado Nuevo León."
  canonicalPath="/mail"
>
  <Navbar />

  <main class="hero">
    <div class="card">

      <img
        src="/logoCM.svg"
        class="logo"
        alt="Colegio Militarizado"
      />

      <h1>Centro de Servicios Digitales</h1>

      <p class="subtitle">
        Bienvenido al ecosistema tecnológico del
        Colegio Militarizado Nuevo León.
      </p>

      <a
        href="https://mail.hostinger.com"
        target="_blank"
        rel="noopener noreferrer"
        class="btn"
      >
        📧 Acceder al Correo Institucional
      </a>

      <div class="coming">

        <div class="service">
          <div class="emoji">🤖</div>
          <span>IA LEÓN</span>
          <small>Próximamente</small>
        </div>

        <div class="service">
          <div class="emoji">🎓</div>
          <span>Portal Académico</span>
          <small>Próximamente</small>
        </div>

        <div class="service">
          <div class="emoji">💻</div>
          <span>Soporte Técnico</span>
          <small>Próximamente</small>
        </div>

      </div>

    </div>
  </main>
</Layout>

<style>

.hero{

min-height:calc(100vh - 80px);

display:flex;

justify-content:center;

align-items:center;

padding:40px 20px;

background:linear-gradient(
135deg,
#081321 0%,
#0b1d2f 50%,
#10462d 100%
);

}

.card{

background:white;

width:100%;

max-width:560px;

padding:38px;

border-radius:24px;

box-shadow:0 20px 60px rgba(0,0,0,.18);

text-align:center;

}

.logo{

width:90px;

margin-bottom:18px;

}

h1{

margin:0;

font-size:3rem;

font-weight:700;

}

.subtitle{

margin-top:18px;

margin-bottom:30px;

font-size:1.1rem;

line-height:1.6;

color:#666;

}

.btn{

display:inline-flex;

justify-content:center;

align-items:center;

padding:18px 34px;

background:#166534;

color:white;

font-weight:700;

font-size:1rem;

border-radius:12px;

text-decoration:none;

transition:.25s;

}

.btn:hover{

background:#15803d;

transform:translateY(-2px);

}

.coming{

margin-top:32px;

display:flex;

justify-content:center;

gap:16px;

flex-wrap:wrap;

}

.service{

width:145px;

height:120px;

background:#f7f7f7;

border-radius:16px;

display:flex;

flex-direction:column;

justify-content:center;

align-items:center;

transition:.25s;

cursor:default;

}

.service:hover{

transform:translateY(-4px);

box-shadow:0 10px 25px rgba(0,0,0,.10);

}

.emoji{

font-size:1.5rem;

margin-bottom:8px;

}

.service span{

font-weight:700;

font-size:.95rem;

}

.service small{

margin-top:6px;

color:#999;

font-size:.82rem;

}

@media(max-width:640px){

.card{

padding:28px;

}

h1{

font-size:2.2rem;

}

.service{

width:100%;

max-width:260px;

height:90px;

}

}

</style>
