---
import "../styles/global.css";
import { Font } from "astro:assets";
import Footer from "../components/Footer.astro";

interface Props {
  seoTitle?: string;
  seoDescription?: string;
  seoImage?: string;
  seoType?: "website" | "article";
  canonicalPath?: string;
  noindex?: boolean;
}

const {
  seoTitle = "Colegio Militarizado",
  seoDescription =
    "Colegio Militarizado con excelencia académica, disciplina y formación integral.",
  seoImage,
  seoType = "website",
  canonicalPath,
  noindex = false,
} = Astro.props as Props;

const site = import.meta.env.SITE;
const canonicalUrl =
  site && canonicalPath
    ? new URL(canonicalPath, site).toString()
    : site
      ? new URL(Astro.url.pathname, site).toString()
      : undefined;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <meta property="og:type" content={seoType} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {seoImage && <meta property="og:image" content={seoImage} />}

    <meta name="twitter:card" content={seoImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    {seoImage && <meta name="twitter:image" content={seoImage} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Google Sans Font -->
    <Font cssVariable="--font-google-sans" preload />
  </head>
  <body>
    <slot />
    <Footer />
  </body>
</html>

<style>
  html {
    margin: 0;
    width: 100%;
    height: 100%;
  }
  
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
