<section class="flex min-h-screen flex-col">
  <header class="border-b border-gray-200 bg-white px-6 py-4">
    <div class="mx-auto flex max-w-5xl items-center justify-between">
      <div>
        <h1 class="text-2xl font-black text-[#1f2933]">IA LEÓN</h1>
        <p id="userContext" class="text-sm text-gray-500">Validando sesión...</p>
      </div>

      <a
        href="/ia-leon/perfil"
        class="rounded-xl bg-[#0b3b2e] px-4 py-2 text-sm font-bold text-white"
      >
        Perfil
      </a>
    </div>
  </header>

  <div id="messages" class="mx-auto flex w-full max-w-5xl flex-1 flex-col gap-4 overflow-y-auto px-6 py-8">
    <div class="max-w-[80%] rounded-2xl bg-white px-5 py-4 text-gray-800 shadow-sm">
      Hola, soy IA LEÓN. ¿En qué puedo ayudarte?
    </div>
  </div>

  <form id="chatForm" class="border-t border-gray-200 bg-white px-6 py-4">
    <div class="mx-auto flex max-w-5xl gap-3">
      <input
        id="messageInput"
        type="text"
        required
        autocomplete="off"
        placeholder="Escribe tu pregunta..."
        class="flex-1 rounded-xl border border-gray-300 px-4 py-3 outline-none focus:border-[#0b3b2e]"
      />

      <button
        type="submit"
        class="rounded-xl bg-[#0b3b2e] px-6 py-3 font-black text-white"
      >
        Enviar
      </button>
    </div>

    <p class="mx-auto mt-2 max-w-5xl text-xs text-gray-500">
      IA LEÓN puede responder solo con información autorizada. No compartas datos sensibles innecesarios.
    </p>
  </form>
</section>

<script>
  const API_URL = import.meta.env.PUBLIC_IA_LEON_API_URL;

  const session = JSON.parse(localStorage.getItem("ia_leon_session") || "null");
  const userContext = document.getElementById("userContext");
  const messages = document.getElementById("messages");
  const chatForm = document.getElementById("chatForm");
  const messageInput = document.getElementById("messageInput");

  if (!session?.token) {
    window.location.href = "/ia-leon";
  }

  if (session?.user && userContext) {
    userContext.textContent = `${session.user.name || "Docente"} · ${session.user.email || ""} · ${session.user.campus || ""}`;
  }

  function addMessage(role, text) {
    const div = document.createElement("div");

    div.className =
      role === "user"
        ? "ml-auto max-w-[80%] rounded-2xl bg-[#d9eadf] px-5 py-4 text-gray-900 shadow-sm"
        : "max-w-[80%] rounded-2xl bg-white px-5 py-4 text-gray-800 shadow-sm";

    div.textContent = text;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;

    return div;
  }

  chatForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const message = messageInput.value.trim();
    if (!message) return;

    addMessage("user", message);
    messageInput.value = "";

    const typing = addMessage("bot", "IA LEÓN está escribiendo...");

    try {
      const response = await fetch(`${API_URL}/chat`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${session.token}`,
        },
        body: JSON.stringify({ message }),
      });

      if (!response.ok) {
        throw new Error("No se pudo obtener respuesta.");
      }

      const data = await response.json();

      typing.remove();
      addMessage("bot", data.answer || "No cuento con esa información.");
    } catch (error) {
      typing.remove();
      addMessage("bot", "No pude conectar con IA LEÓN en este momento.");
    }
  });
</script>