<script is:inline src="https://livechat-v2.chat2desk.com.mx/packs/ie-11-support.js"></script>

<script is:inline>
  window.chat24_token = "6f023931b49ec7afb1bedcfca266bd3e";
  window.chat24_url = "https://livechat-v2.chat2desk.com.mx";
  window.chat24_socket_url = "wss://livechat-v2.chat2desk.com.mx/widget_ws_new";
  window.chat24_static_files_domain = "https://storage.chat2desk.com.mx/";
  window.lang = "es";

  function removeChat2DeskFooter() {
    document
      .querySelectorAll(".messages__footer, .messages__footer--light")
      .forEach((el) => {
        el.remove();
      });
  }

  const observer = new MutationObserver(() => {
    removeChat2DeskFooter();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true,
  });

  window
    .fetch(`${window.chat24_url}/packs/manifest.json?nocache=${new Date().getTime()}`)
    .then((res) => res.json())
    .then((data) => {
      const chat24 = document.createElement("script");
      chat24.type = "text/javascript";
      chat24.async = true;
      chat24.src = `${window.chat24_url}${data["application.js"]}`;
      document.body.appendChild(chat24);

      setTimeout(removeChat2DeskFooter, 500);
      setTimeout(removeChat2DeskFooter, 1500);
      setTimeout(removeChat2DeskFooter, 3000);
    });
</script>