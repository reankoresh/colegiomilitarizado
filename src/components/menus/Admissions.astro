---
import Title from "../ui/Title.astro";
import { GraduationCap, BookOpen, MessageSquare, FileAudio, Library, ClipboardList } from "lucide-astro";
---

<!-- Menú compartido de Admisiones: MODELS y TOOLS -->
<div class="flex flex-col md:flex-row gap-0 md:gap-3">
  <!-- Columna MODELS -->
  <div class="md:flex-1 md:pr-3">
    <Title tag="h6" color="white">Admisiones 2026</Title>
    <div class="space-y-3">
      <a
        href="https://www.uanl.mx/tramites/registro-de-aspirantes-bachillerato/"
        class="block rounded-md px-3 py-2 text-base font-medium text-white hover:text-gray-900 hover:bg-gray-100 transition-colors duration-150"
      >
        <span class="inline-flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full ring-1 ring-stone-300 text-stone-500 bg-white">
            <ClipboardList class="h-4 w-4" aria-hidden="true" />
          </span>
          <span class="flex flex-col">
            <span class="font-medium">Proceso de Asignación de Espacios</span>
            <span class="text-xs opacity-80 font-normal">
              de la Secretaría de Educación.
            </span>
          </span>
        </span>
      </a>

      <a
        href="/preparatoria"
        class="block rounded-md px-3 py-2 text-base font-medium text-white hover:text-gray-900 hover:bg-gray-100 transition-colors duration-150"
      >
        <span class="inline-flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full ring-1 ring-stone-300 text-stone-500 bg-white">
            <GraduationCap class="h-4 w-4" aria-hidden="true" />
          </span>
          <span class="flex flex-col">
            <span class="font-medium">Preparatoria</span>
            <span class="text-xs opacity-80 font-normal">
              Únete a nuestra Preparatoria y potencia tu futuro.
            </span>
          </span>
        </span>
      </a>
      <a
        href="/ues"
        class="block rounded-md px-3 py-2 text-base font-medium text-white hover:text-gray-900 hover:bg-gray-100 transition-colors duration-150"
      >
        <span class="inline-flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full ring-1 ring-stone-300 text-stone-500 bg-white">
            <BookOpen class="h-4 w-4" aria-hidden="true" />
          </span>
          <span class="flex flex-col">
            <span class="font-medium">Estudios Superiores</span>
            <span class="text-xs opacity-80 font-normal">
              Da el siguiente paso con nuestros Estudios Superiores.
            </span>
          </span>
        </span>
      </a>
    </div>
  </div>

  <!-- Separador (solo desktop) -->
  <div class="hidden md:block w-px bg-gray-400/30 mx-1 rounded-full self-stretch">
  </div>

  <!-- Columna TOOLS -->
  <div class="md:flex-1 md:pl-3">
    <Title tag="h6" color="white">Herramientas</Title>
    <div class="space-y-3">
      <a
        href="https://buscador.becasbenitojuarez.gob.mx/escuelas-buems/"
        class="block rounded-md px-3 py-2 text-base font-medium text-white hover:text-gray-900 hover:bg-gray-100 transition-colors duration-150"
      >
        <span class="inline-flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full ring-1 ring-stone-300 text-stone-500 bg-white">
            <MessageSquare class="h-4 w-4" aria-hidden="true" />
          </span>
          <span class="flex flex-col">
            <span class="font-medium">Beca Benito Júarez</span>
            <span class="text-xs opacity-80 font-normal">
              Apoyo para que jóvenes continúen sus estudios.
            </span>
          </span>
        </span>
      </a>

      <a
        href="https://www.imss.gob.mx/faq/seguro-estudiantes"
        class="block rounded-md px-3 py-2 text-base font-medium text-white hover:text-gray-900 hover:bg-gray-100 transition-colors duration-150"
      >
        <span class="inline-flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full ring-1 ring-stone-300 text-stone-500 bg-white">
            <FileAudio class="h-4 w-4" aria-hidden="true" />
          </span>
          <span class="flex flex-col">
            <span class="font-medium">Seguro Social para Estudiantes</span>
            <span class="text-xs opacity-80 font-normal">
              Servicios médicos gratuitos para estudiantes.
            </span>
          </span>
        </span>
      </a>

      <a
        href="https://www.nl.gob.mx/es/boletines/anuncian-samuel-y-mariana-ayudamos-los-estudiantes-tarifa-preferencial-para-estudiantes"
        class="block rounded-md px-3 py-2 text-base font-medium text-white hover:text-gray-900 hover:bg-gray-100 transition-colors duration-150"
      >
        <span class="inline-flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full ring-1 ring-stone-300 text-stone-500 bg-white">
            <Library class="h-4 w-4" aria-hidden="true" />
          </span>
          <span class="flex flex-col">
            <span class="font-medium">Ayudemos a los Estudiantes</span>
            <span class="text-xs opacity-80 font-normal">
              Tarifa preferencial de estudiantes para transporte público.
            </span>
          </span>
        </span>
      </a>

    </div>
  </div>
</div>
