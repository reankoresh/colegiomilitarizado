---
const portalUrl = "https://www.uanl.mx/tramites/registro-de-aspirantes-bachillerato/";
---

<div id="uanl-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4">
  <div class="w-full max-w-xl rounded-2xl bg-white p-6 shadow-[0px_0px_10px_0px] shadow-black/10 md:p-8">
    <div class="flex items-start justify-between gap-4">
      <h2 class="text-2xl font-semibold text-gray-800">Convocatoria UANL</h2>
      <button
        id="uanl-close-btn"
        type="button"
        class="rounded-full p-2 text-gray-600 transition hover:bg-gray-100 hover:text-gray-900"
        aria-label="Cerrar anuncio"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>

    <p class="mt-4 text-base leading-relaxed text-gray-700">
      Esta es tu oportunidad. Regístrate en el portal de la UANL del 13 de marzo al 30 de abril de 2026.
    </p>

    <a
      href={portalUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="cursor-pointer mt-6 inline-flex items-center justify-center rounded-full bg-orange-500 px-5 py-2.5 font-medium text-white"
    >
      Ir al portal de la UANL
    </a>
  </div>
</div>

<script>
  const modal = document.getElementById("uanl-modal");
  const closeButton = document.getElementById("uanl-close-btn");

  const closeModal = () => {
    modal?.classList.add("hidden");
  };

  closeButton?.addEventListener("click", closeModal);

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeModal();
    }
  });
</script>